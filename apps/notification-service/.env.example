# Variaveis de ambiente para o serviço de notificação
MAIL_HOST= # SMTP host for the notification service
MAIL_PORT= # SMTP port for the notification service
MAIL_IGNORE_TLS= # Whether to ignore TLS for the notification service
MAIL_SECURE= # Whether to use secure connection for the notification service
MAIL_USER= # SMTP user for the notification service
MAIL_PASSWORD= # SMTP password for the notification service
MAIL_FROM= # Default email address for the notification service
MAIL_TEMPLATE_DIR= # Directory for email templates for the notification service
DATABASE_URL= # PostgreSQL URL for the observability service
NATS_URL= # NATS URL for the notification service